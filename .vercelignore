# Native build outputs — Vercel only needs the web bundle.
# NOTE: modules/ is NOT excluded — package.json references local Expo modules
# via `file:modules/local-file-bookmark`, so npm install needs the folder to
# resolve those entries even though the iOS-specific JS gets stubbed on web
# via .web.ts overrides (see e.g. CloudFileService.web.ts).
ios/
android/
*.xcworkspace/
*.xcodeproj/

# CocoaPods
ios/Pods/
ios/Podfile.lock

# Native build artifacts
*.apk
*.aab
*.ipa

# Local dev
.expo/
.expo-shared/
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Tests / coverage
coverage/
__tests__/
__mocks__/
